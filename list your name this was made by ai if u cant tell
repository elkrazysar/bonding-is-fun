-- FARM button
local function MakeHudBtn(lbl, px, py)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 75, 0, 75)
    btn.Position = UDim2.new(px, 0, py, 0)
    btn.AnchorPoint = Vector2.new(0.5, 0.5)
    btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    btn.BackgroundTransparency = 0.3
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 14
    btn.Text = lbl
    btn.Parent = hudGui
    Instance.new("UICorner", btn).CornerRadius = UDim.new(1, 0)
    local s = Instance.new("UIStroke", btn)
    s.Color = Color3.fromRGB(255,255,255)
    s.Thickness = 1.5

    local dragging, dragDelta, dragStart, startPos = false, 0, nil, nil
    btn.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.Touch or inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true; dragDelta = 0
            dragStart = inp.Position; startPos = btn.Position
        end
    end)
    btn.InputChanged:Connect(function(inp)
        if dragging and (inp.UserInputType == Enum.UserInputType.Touch or inp.UserInputType == Enum.UserInputType.MouseMove) then
            local d = inp.Position - dragStart
            dragDelta = d.Magnitude
            btn.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + d.X, startPos.Y.Scale, startPos.Y.Offset + d.Y)
        end
    end)
    btn.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.Touch or inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    return btn, function() return dragDelta end
end

