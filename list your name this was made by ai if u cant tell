-- ══════════════════════════════
-- Cowboy: CFrame touch collect
-- ══════════════════════════════
local BondNames = {"Bond", "bond", "CashBond", "Cash_Bond", "MoneyBag", "GoldBond"}
local function FindBonds()
    local found = {}
    for _, obj in ipairs(workspace:GetDescendants()) do
        for _, name in ipairs(BondNames) do
            if obj.Name:lower():find(name:lower()) then
                local part = obj:IsA("Model") and (obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")) or obj
                if part then
                    table.insert(found, part)
                    break
                end
            end
        end
    end
    return found
end

local function StartCowboyAura(root)
    AuraThread = task.spawn(function()
        while FarmActive do
            local bonds = FindBonds()
            for _, part in ipairs(bonds) do
                if not FarmActive then return end
                local prev = root.CFrame
                pcall(function()
                    root.CFrame = part.CFrame
                    task.wait(0.05)
                    root.CFrame = prev
                    RunBonds   = RunBonds + 1
                    BondsTotal = BondsTotal + 1
                end)
                task.wait(CollectWaitTime)  -- << Collect Wait Time slider
            end
            task.wait(MainWaitTime)         -- << Main Wait Time slider
        end
    end)
end

-- ══════════════════════════════
-- Rail traversal
-- ══════════════════════════════
local function RunRailSession(root)
    local velo   = 1500
    local tRails = {}

    for _, obj in ipairs(workspace:WaitForChild("RailSegments"):GetDescendants()) do
        if obj:IsA("BasePart") and obj.Name == "Guide" then
            table.insert(tRails, obj)
        end
    end

    local function pathway(pos)
        local closest, dist = nil, math.huge
        for _, rail in ipairs(tRails) do
            local d = (rail.Position - pos).Magnitude
            if d < dist then dist = d; closest = rail end
        end
        return closest
    end

    workspace.CurrentCamera.CameraType = Enum.CameraType.Scriptable

    local currentRail = pathway(root.Position)
    local currentPos  = currentRail and currentRail.Position or root.Position
    local tVisited    = {}
    local lastDir     = Vector3.new(0, 0, 1)

    while FarmActive do
        if currentRail then
            tVisited[currentRail] = true
            lastDir = currentRail.CFrame.LookVector.Unit
        end

        local targetPos = currentPos - lastDir * 20
        local distance  = (targetPos - currentPos).Magnitude
        local duration  = distance / velo
        local start     = tick()

        while tick() - start < duration do
            if not FarmActive then return end
            local t   = (tick() - start) / duration
            local pos = currentPos:Lerp(targetPos, t)
            root.CFrame = CFrame.new(pos)
            workspace.CurrentCamera.CFrame = CFrame.new(pos + Vector3.new(0, 15, 0), pos)
            RunService.RenderStepped:Wait()
        end

        currentPos = targetPos

        -- Wait between positions (Main Wait Time)
        task.wait(MainWaitTime)

        local nextRail = nil
        local bDot     = 0.5

        for _, rail in ipairs(tRails) do
            if not tVisited[rail] then
                local toRail = (rail.Position - currentPos).Unit
                local dot    = lastDir:Dot(toRail)
                if dot > bDot and (rail.Position - currentPos).Magnitude < 50 then
                    bDot     = dot
                    nextRail = rail
                end
            end
        end

        -- End of track → die
        if not nextRail then
            StatusText = "End of rails — dying..."
            task.wait(0.5)
            DieAndRestart()
            return
        end

        currentRail = nextRail
    end
end

-- ══════════════════════════════
-- Session runner
-- ══════════════════════════════
local function RunFarmSession()
    local Char = LP.Character
    if not Char then return end
    local root = Char:WaitForChild("HumanoidRootPart", 5)
    if not root then return end

    RunBonds   = 0
    RunCount   = RunCount + 1
    StatusText = "Run #" .. RunCount .. " | " .. Mode

    if Mode == "Cowboy" then
        TrySetCowboy()
        task.wait(1)
        StartCowboyAura(root)
    else
        StartAura()
    end

    RailThread = task.spawn(function()
        RunRailSession(root)
    end)

    KillThread = task.delay(45, function()
        if FarmActive then
            StatusText = "Safety kill — restarting..."
            DieAndRestart()
        end
    end)
end

local function StartFarm()
    FarmActive = true
    BondsTotal = 0
    RunCount   = 0

    LP.CharacterAdded:Connect(function()
        if not FarmActive then return end
        StopThreads()
        task.wait(2)
        pcall(function() workspace.CurrentCamera.CameraType = Enum.CameraType.Custom end)
        RunFarmSession()
    end)

    if LP.Character then RunFarmSession() end
end

local function StopFarm()
    FarmActive = false
    StopThreads()
    StatusText = "Idle"
    pcall(function() workspace.CurrentCamera.CameraType = Enum.CameraType.Custom end)
end

